{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Métadonnées — The Division 2",
  "type": "object",
  "required": ["titre", "version"],
  "properties": {
    "titre": { "type": "string" },
    "version": { "type": "string", "description": "Version du jeu / mise à jour" },
    "credits": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Liste des contributeurs"
    },
    "maxExpertiseLevel": {
      "type": "integer",
      "minimum": 0,
      "description": "Niveau maximum d'expertise applicable sur le jeu"
    },
    "changelog": {
      "type": "array",
      "description": "Historique des modifications de la base de données",
      "items": {
        "type": "object",
        "required": ["date"],
        "properties": {
          "date": {
            "oneOf": [
              {
                "type": "string",
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
                "description": "Date de la mise à jour (YYYY-MM-DD)"
              },
              {
                "type": "object",
                "required": ["from", "to"],
                "properties": {
                  "from": {
                    "type": "string",
                    "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
                    "description": "Date de début (YYYY-MM-DD)"
                  },
                  "to": {
                    "type": "string",
                    "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
                    "description": "Date de fin (YYYY-MM-DD)"
                  }
                },
                "additionalProperties": false,
                "description": "Plage de dates de la mise à jour"
              }
            ]
          },
          "patch": { "type": "string", "description": "Nom du patch associé (ex: TU22)" },
          "changements": {
            "type": "array",
            "description": "Liste des changements effectués (chaque élément peut être une chaîne Markdown ou un objet pliable)",
            "items": {
              "oneOf": [
                { "type": "string", "description": "Contenu au format Markdown pris en charge" },
                {
                  "type": "object",
                  "required": ["titre", "description"],
                  "properties": {
                    "titre": { "type": "string", "description": "Titre affiché quand l'élément est replié" },
                    "description": {
                      "oneOf": [
                        { "type": "string", "description": "Contenu détaillé au format Markdown" },
                        { "type": "array", "items": { "type": "string" }, "description": "Liste de chaînes à afficher sous forme de liste Markdown" }
                      ]
                    }
                  },
                  "additionalProperties": false
                }
              ]
            }
          }
        },
        "additionalProperties": false
      }
    }
  }
}
