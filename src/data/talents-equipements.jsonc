  },
  "ostracisation": {
    "nom": "Ostracisation",
    "icone": "ostracisation",
    "description": "Toucher un ennemi lui applique une marque. La marque disparaît au bout de 15s, ou à la mort de l'ennemi marqué.Vous subissez +600% de dégâts de l'ennemi marqué.Vous infligez +20% de dégâts aux ennemis non marqués.S'il ne reste qu'un ennemi en combat, la marque disparaît et ne peut pas être appliquée de nouveau.",
    "emplacement": "masque",
    "estExotique": true
  },
  "elimination_confirmee": {
    "nom": "Élimination confirmée",
    "icone": "elimination_confirmee",
    "description": "Les ennemis éliminés génèrent un trophée. La récupération des trophées fournit à la fois un buff à court terme et à long terme. Le premier buff dépend du nombre d'attribut essentiels équipés et dure 10s.Offensif - +5% de dégâts d'armeDéfensif - +10% de protection bonusUtilitaire - +5% d'efficacité de compétencePour chaque trophée récupéré, vous obtenez en plus +1% de dégâts d'arme, +1% d'efficacité de compétence et 0,1% de régénération de protection pendant 300s.Effet cumulable 30 fois.",
    "emplacement": "sac_a_dos",
    "estExotique": true
  },
  "debrouillardise": {
    "nom": "Débrouillardise",
    "icone": "debrouillardise",
    "description": "Utilise tout objet d'ensemble d'équipement et/ou de marque équipé pour remplir une condition de déverrouillage de bonus d'ensemble. Peut déverrouiller les bonus de plusieurs ensembles simultanément.",
    "emplacement": "sac_a_dos",
    "estExotique": true
  },
  "medecin_de_combat": {
