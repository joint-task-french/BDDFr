{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Talents d'équipements",
  "description": "Clé = slug du talent.",
  "type": "object",
  "additionalProperties": false,
  "patternProperties": {
    "^[a-z0-9_]+$": {
      "type": "object",
      "required": [
        "nom",
        "emplacement"
      ],
      "anyOf": [
        { "required": ["description"] },
        { "required": ["perfectDescription"] }
      ],
      "properties": {
        "nom": {
          "type": "string"
        },
        "icon": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$",
          "description": "Slug du fichier icône dans game_assets/talents/equipements/ (sans .png)"
        },
        "description": {
          "type": "string"
        },
        "prerequis": {
          "type": "string"
        },
        "estExotique": {
          "type": "boolean",
          "description": "True si talent exotique (dédié à un équipement exotique)."
        },
        "emplacement": {
          "type": "string",
          "enum": [
            "torse",
            "sac_a_dos",
            "masque",
            "holster",
            "gants",
            "genouilleres",
            "gear_set"
          ],
          "description": "Sur quel emplacement le talent peut être utilisé"
        },
        "gearSet": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$",
          "description": "Slug de l'ensemble (si talent de gear set)"
        },
        "perfectDescription": {
          "type": "string",
          "description": "Description de la version parfaite du talent"
        },
        "equipementsParfaits": {
          "type": "array",
          "description": "Noms des équipements nommés qui portent la version parfaite de ce talent",
          "items": {
            "pattern": "^[a-z0-9_]+$",
            "type": "string"
          }
        },
        "notes": {
          "type": "string",
          "description": "Notes libres sur le talent"
        },
        "descente": {
          "$ref": "../common/descente.schema.json"
        }
      }
    }
  }
}