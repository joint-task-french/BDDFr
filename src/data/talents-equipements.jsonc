// Talents d'équipements — The Division 2
{
  "complementarite": {
    "nom": "Complémentarité",
    "description": "Le dernier ennemi blessé par une compétence est marqué.\nInfliger des dégâts d'arme à cet ennemi supprime la marque et diminue les temps de recharge de 6s.\nNe consomme pas la marque si aucune compétence n'est en recharge.\nTemps de recharge : 4s",
    "emplacement": "torse"
  },
  "dynamisation": {
    "nom": "Dynamisation",
    "description": "Au combat, chaque compétence génère un bonus cumulable si elle est active ou si elle n'est pas en recharge.\nCes bonus augmentent le total de dégâts de compétence de 1,5% et le total de réparation de compétence de 2%.\nIls sont cumulables 15 fois maximum par compétence et s'annulent quand la compétence est en recharge.",
    "emplacement": "sac_a_dos",
    "descente": {
      "boucles": [
        "Gourmandise",
        "Paresse"
      ],
      "categorie": "exotique",
      "levels": {
        "base": "Au combat, chaque compétence génère un bonus cumulable si elle est active ou si elle n'est pas en recharge.\nCes bonus augmentent le total de dégâts de compétence de {skill_damage}% et le total de réparation de compétence de {skill_repair}%.\nIls sont cumulables {max_stacks} fois maximum par compétence et s'annulent quand la compétence est en recharge.",
        "1": {
          "skill_damage": 1.5,
          "skill_repair": 2.0,
          "max_stacks": 15
        }
      }
    }
  },
  "doue": {
    "nom": "Doué",
    "description": "Les éliminations par compétence ont 25% de probabilité de réinitialiser les recharges de compétence.",
    "emplacement": "torse",
    "perfectDescription": "Les éliminations par compétence ont 30% de probabilité de réinitialiser les recharges de compétence.",
