{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Mods d'armes — The Division 2",
  "description": "Clé = slug du mod.",
  "type": "object",
  "additionalProperties": false,
  "patternProperties": {
    "^[a-z0-9_]+$": {
      "type": "object",
      "required": [
        "nom",
        "type",
        "compatible"
      ],
      "properties": {
        "nom": {
          "type": "string",
          "description": "Nom de la modification"
        },
        "type": {
          "type": "string",
          "enum": [
            "chargeur",
            "canon",
            "viseur",
            "bouche"
          ],
          "description": "Type de modification"
        },
        "attributs": {
          "type": "array",
          "description": "Attributs modifiés par ce mod (slug + valeur, négatif = malus)",
          "items": {
            "type": "object",
            "required": [
              "attribut",
              "valeur"
            ],
            "properties": {
              "attribut": {
                "type": "string",
                "pattern": "^[a-z0-9_]+$"
              },
              "valeur": {
                "type": "number"
              }
            },
            "additionalProperties": false
          }
        },
        "bonus": {
          "type": "string",
          "description": "Effet textuel non lié à un attribut (optionnel)"
        },
        "compatible": {
          "type": "array",
          "description": "Emplacements spécifiques compatibles (ex: ['rail_optique_court', 'micro_rail_optique']). Tableau vide = universel pour ce type global.",
          "items": {
            "type": "string",
            "enum": [
              "chargeur_556",
              "chargeur_762",
              "chargeur_762_precision",
              "chargeur_integre",
              "chargeur_pistolet",
              "barillet",
              "bande_munitions",
              "chargeur_45_acp",
              "chargeur_9mm",
              "magasin_tubulaire",

              "rail_sous_canon_long",
              "rail_sous_canon_court",
              "gadget",

              "rail_optique_court",
              "rail_optique_long",
              "micro_rail_optique",
              "rail_optique",

              "bouche_45_acp",
              "bouche_9mm",
              "bouche_556",
              "bouche_762",
              "bouche"
            ]
          }
        },
        "estExotique": {
          "type": "boolean",
          "description": "True si mod exotique lié à une arme exotique"
        },
        "prerequis": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$",
          "description": "Slug de spécialisation requise (optionnel)"
        },
        "notes": {
          "type": "string",
          "description": "Notes libres sur le mod"
        }
      },
      "additionalProperties": false
    }
  }
}
