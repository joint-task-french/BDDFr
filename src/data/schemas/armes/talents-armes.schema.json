{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Talents d'armes",
  "description": "Clé = slug du talent.",
  "type": "object",
  "additionalProperties": false,
  "patternProperties": {
    "^[a-z0-9_]+$": {
      "type": "object",
      "required": [
        "nom"
      ],
      "properties": {
        "nom": {
          "type": "string"
        },
        "icon": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$",
          "description": "Slug du fichier icône dans game_assets/talents/arme/ (sans .png)"
        },
        "description": {
          "type": "string"
        },
        "prerequis": {
          "type": "string"
        },
        "estExotique": {
          "type": "boolean",
          "description": "True si talent exotique (dédié à une arme exotique)."
        },
        "perfectDescription": {
          "type": "string",
          "description": "Description de la version parfaite du talent"
        },
        "armesParfaites": {
          "type": "array",
          "description": "Noms des armes nommées qui portent la version parfaite de ce talent",
          "items": {
            "pattern": "^[a-z0-9_]+$",
            "type": "string"
          }
        },
        "compatibilite": {
          "type": "object",
          "description": "Types d'armes compatibles (true) ou non (false). Si absent, compatible avec tout.",
          "patternProperties": {
            "^[a-z0-9_]+$": {
              "type": "boolean"
            }
          }
        },
        "notes": {
          "type": "string",
          "description": "Notes libres sur le talent"
        },
        "descente": {
          "$ref": "../common/descente.schema.json"
        }
      }
    }
  }
}