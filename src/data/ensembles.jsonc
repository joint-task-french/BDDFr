  },
  "true_patriot": {
    "nom": "True Patriot",
    "type": "gear_set",
    "icon": "true_patriot",
    "attributsEssentiels": [
      "défensif"
    ],
    "bonus2pieces": "+30% Capacité Munitions",
    "bonus3pieces": "+30% Taille du chargeur",
    "bonus4pieces": "Rouge, Blanc et Bleu :Toutes les 2s, les ennemis sur lesquels vous tirez subissent un débuff cumulable de \"rouge\", \"blanc\" et \"bleu\" Rouge : augmente les dégâts subis par l'ennemi de 8% Blanc : toucher l'ennemi répare votre défensif et celle de vos alliés de 2% à chaque seconde. Bleu : diminue les dégâts infligés par l'ennemi de 8%. Tricolore :Les ennemis qui meurent quand ils sont sous les effets des 3 débuffs déclenchent une explosion de 5m de rayon infligeant des dégâts équivalant à leur total de santé et de défensif. (Les dégâts de l'explosion sont réduits si c'est un ennemi spécifié qui meurt).",
    "talentTorse": "drapeau_brandi",
    "talentSac": "elan_patriotique"
  },
