  "maillon_faible": {
    "nom": "Maillon faible",
    "icone": "maillon_faible",
    "description": "Dégâts d'arme accrus de 30% contre les ennemi des rangs les plus faibles actuellement en combat, selon la hiérarchie des Tiers.Tier 1 : chasseur, renégat, chef, tank, bouclier, armes lourdes, lance-roquettes, médecin, contrôleur, chien de guerre, maraudeurTier 2 : support, ingénieur, garde du corps, immobilisateir, poseur de bombe, mini-char, opérateur de droneTier 3 : tout autre ennemi ou proxy de compétence",
    "emplacement": "masque",
    "estExotique": true
  },
  "parkour": {
    "nom": "Parkour !",
