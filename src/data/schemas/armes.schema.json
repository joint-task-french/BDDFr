{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Armes — The Division 2",
  "description": "Toutes les armes (classiques + exotiques) avec statistiques et talents",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["nom", "type"],
    "properties": {
      "nom": { "type": "string", "description": "Nom de l'arme" },
      "icone": { "type": "string", "description": "Slug du fichier icône du talent exotique/nommé dans game_assets/talents/arme/ (sans .png)" },
      "type": {
        "type": "string",
        "enum": ["fusil_assaut", "fusil", "fusil_precision", "pistolet_mitrailleur", "fusil_mitrailleur", "calibre_12", "pistolet", "arme_specifique", "autre"],
        "description": "Type/catégorie de l'arme"
      },
      "fabricant": { "type": "string", "description": "Fabricant de l'arme" },
      "portee": { "type": "number", "description": "Portée optimale en mètres" },
      "rpm": { "type": "integer", "description": "Coups par minute" },
      "chargeur": { "type": "integer", "description": "Taille du chargeur" },
      "rechargement": { "type": "number", "description": "Temps de rechargement en secondes" },
      "headshot": { "type": "string", "description": "Multiplicateur de headshot" },
      "attributEssentiel": { "type": "string", "description": "Attribut essentiel spécifique" },
      "degatsBase": { "type": "integer", "description": "Dégâts de base" },
      "degatsMax": { "type": "integer", "description": "Dégâts maximum" },
      "estExotique": { "type": "boolean", "description": "True si arme exotique" },
      "estNomme": { "type": "boolean", "description": "True si arme nommée (talent dédié fixe)" },
      "talents": {
        "type": "array",
        "description": "Liste de slugs de talents (référencent les noms dans talents-armes.jsonc). Pour les exotiques, les talents dédiés sont directement dans cette liste.",
        "items": { "type": "string" }
      },
      "obtention": { "type": "string", "description": "Comment obtenir l'arme" }
    }
  }
}
