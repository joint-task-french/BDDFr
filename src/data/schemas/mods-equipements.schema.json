{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Mods d'équipements — The Division 2",
  "description": "Clé = slug du mod.",
  "type": "object",
  "additionalProperties": false,
  "patternProperties": {
    "^[a-z0-9_]+$": {
      "type": "object",
      "required": [
        "statistique"
      ],
      "properties": {
        "categorie": {
          "type": "string",
          "enum": [
            "offensif",
            "défensif",
            "utilitaire"
          ]
        },
        "protocole": {
          "type": "string"
        },
        "statistique": {
          "type": "string"
        },
        "valeurMax": {
          "type": "string"
        }
      }
    }
  }
}
