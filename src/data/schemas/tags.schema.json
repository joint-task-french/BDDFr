{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Tags de Build",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "label", "color"],
    "properties": {
      "id": {
        "type": "string",
        "description": "Identifiant unique du tag (ex: dps, tank)"
      },
      "label": {
        "type": "string",
        "description": "Nom affiché du tag"
      },
      "color": {
        "type": "string",
        "description": "Couleur CSS ou classe Tailwind associée"
      }
    }
  }
}