{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Équipements — The Division 2",
  "description": "Toutes les pièces d'équipement (gear sets, marques, nommés, exotiques)",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["nom", "emplacement"],
    "properties": {
      "nom": { "type": "string" },
      "marque": { "type": "string", "description": "Nom de la marque, du gear set, ou 'Exotique'" },
      "emplacement": {
        "type": "string",
        "enum": ["masque", "torse", "holster", "sac_a_dos", "gants", "genouilleres", "inconnu"],
        "description": "Emplacement sur le personnage"
      },
      "attributEssentiel": { "type": "string" },
      "categorieAttribut": {
        "type": "string",
        "enum": ["degats", "protection", "competences", ""],
        "description": "Catégorie de l'attribut essentiel par défaut : degats, protection ou competences"
      },
      "attribut1": { "type": "string" },
      "attributUnique": { "type": "string" },
      "talent": { "type": "string", "description": "Ancien champ talent — migrer vers talents[]" },
      "talents": {
        "type": "array",
        "description": "Liste de slugs de talents (référencent les noms dans talents-equipements.jsonc). Pour les exotiques, les talents dédiés.",
        "items": { "type": "string" }
      },
      "mod": { "type": "string" },
      "estNomme": { "type": "boolean" },
      "estExotique": { "type": "boolean" },
      "source": {
        "type": "string",
        "enum": ["gear_set", "marque", "exotic"],
        "description": "Provenance de la pièce"
      },
      "obtention": { "type": "string", "description": "Comment obtenir l'équipement" }
    }
  }
}
