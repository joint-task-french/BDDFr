{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Talents autres (Descente)",
  "description": "Talents spécifiques au mode Descente qui ne sont ni des talents d'armes ni d'équipements. Clé = slug du talent.",
  "type": "object",
  "additionalProperties": false,
  "patternProperties": {
    "^[a-z0-9_]*$": {
      "type": "object",
      "required": [
        "nom",
        "descente"
      ],
      "properties": {
        "nom": {
          "type": "string"
        },
        "icon": {
          "type": "string",
          "description": "Slug du fichier icône (optionnel)"
        },
        "descente": {
          "type": "object",
          "description": "Données spécifiques au mode de jeu Descente",
          "required": ["boucles", "categorie", "levels"],
          "properties": {
            "boucles": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "categorie": {
              "type": "string",
              "enum": ["offensif", "defensif", "utilitaire", "exotique"]
            },
            "notes": {
              "type": "string",
              "description": "Notes spécifiques au mode Descente"
            },
            "levels": {
              "type": "object",
              "required": ["base"],
              "properties": {
                "base": {
                  "type": "string",
                  "description": "Description du talent avec variables : {var_name}, {other_var_name}..."
                }
              },
              "additionalProperties": {
                "type": "object",
                "description": "Valeurs des variables pour un niveau donné (ex: '1', '2', etc.)",
                "additionalProperties": {
                  "oneOf": [
                    {"type": "string"},
                    {"type": "number"}
                  ]
                }
              }
            }
          }
        }
      }
    }
  }
}
