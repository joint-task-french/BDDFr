        "1": {
          "reset_chance": 25
        }
      }
    }
  },
  "observateur": {
    "nom": "Observateur",
    "description": "Augmente les totaux de dégâts d'arme et de dégâts de compétence de 15% contre les ennemis touchés par impulsion.",
    "emplacement": "torse",
    "equipementsParfaits": ["ampli_de_reperage"],
    "perfectDescription": "Augmente les totaux de dégâts d'arme et de dégâts de compétence de 20% contre les ennemis touchés par impulsion."
  },
  "livraison_explosive": {
    "nom": "Livraison Explosive",
    "description": "Quand vous déployez un objet de compétence, 1.5s après que celui-ci touche le sol, il génère une explosion infligeant des dégâts aux ennemis situés à moins de 5m.\nLes dégâts sont étalonnés selon le Tier de compétence et infligent 25-100% des dégâts d'une grenade offensive.\nUne fois maximum par compétence.",
    "emplacement": "torse",
    "perfectDescription": "Quand vous déployez un objet de compétence, 1.5s après que celui-ci touche le sol, il génère une explosion infligeant des dégâts aux ennemis situés à moins de 5m. Ensuite, les explosions se produisent toutes les 5s.\nLes dégâts sont étalonnés selon le Tier de compétence et infligent 25-100% des dégâts d'une grenade offensive.\nUne fois maximum par compétence.",
    "equipementsParfaits": ["combustor"]
  },
  "determination_empathique": {
    "nom": "Détermination Empathique",
    "description": "Réparer un allié augmente ses totaux de dégâts d'arme et de dégâts de compétence de 3-15% pendant 20s.\nSur soi, le bénéfice est de 1-7%.\nL'efficacité augmente en fonction de votre Tier de compétence.",
    "emplacement": "torse"
  },
  "observation": {
    "nom": "Observation",
    "description": "Au bout de 10s à couvert, augmente les totaux de dégâts d'arme et de dégâts de compétence de 12% pour vous et vos alliés.\nCet effet dure tant que vous restez à couvert ou que vous vous déplacez d'un abri à l'autre.",
    "emplacement": "torse",
    "perfectDescription": "Au bout de 8s à couvert, augmente les totaux de dégâts d'arme et de dégâts de compétence de 14% pour vous et vos alliés.\nCet effet dure tant que vous restez à couvert ou que vous vous déplacez d'un abri à l'autre.",
    "equipementsParfaits": ["calme_agressif"],
    "descente": {
      "boucles": [
        "Gourmandise",
        "Paresse"
      ],
      "categorie": "offensif",
      "levels": {
        "base": "Au bout de {activation_time}s à couvert, augmente les totaux de dégâts d'arme et de dégâts de compétence de {damage_bonus}% pour vous et vos alliés.\nCet effet dure tant que vous restez à couvert ou que vous vous déplacez d'un abri à l'autre.",
        "1": {
          "activation_time": 10,
          "damage_bonus": 12
        }
      }
    }
  },
  "intimidation": {
    "nom": "Intimidation",
    "description": "Quand vous disposez d'une protection bonus, vous gagnez 3 effets chaque seconde jusqu'à un max de 9.\nChaque effet cumulé augmente les dégâts d'arme de +4% contre les ennemis situés à moins de 10m.\nTous les effets cumulés sont perdus si vous n'avez plus de protection bonus.",
    "emplacement": "torse",
    "perfectDescription": "Quand vous disposez d'une protection bonus, vous gagnez 3 effets chaque seconde jusqu'à un max de 10.\nChaque effet cumulé augmente les dégâts d'arme de +4% contre les ennemis situés à moins de 10m.\nTous les effets cumulés sont perdus si vous n'avez plus de protection bonus.",
    "equipementsParfaits": ["chasseur_tueur"],
    "descente": {
      "boucles": [
        "Avidité",
        "Colère",
        "Paresse"
      ],
      "categorie": "offensif",
      "levels": {
        "base": "Quand vous disposez d'une protection bonus, vous gagnez {stacks_per_sec} effets chaque seconde jusqu'à un max de {max_stacks}.\nChaque effet cumulé augmente les dégâts d'arme de +{damage_per_stack}% contre les ennemis situés à moins de {range}m.\nTous les effets cumulés sont perdus si vous n'avez plus de protection bonus.",
        "1": {
          "stacks_per_sec": 3,
          "max_stacks": 9,
          "damage_per_stack": 4,
          "range": 10
        }
      }
    }
  },
