{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Talents d'équipements",
  "description": "Clé = slug du talent.",
  "type": "object",
  "additionalProperties": false,
  "patternProperties": {
    "^[a-z0-9_]+$": {
      "type": "object",
      "required": [
        "nom",
        "emplacement"
      ],
      "properties": {
        "nom": {
          "type": "string"
        },
        "icone": {
          "type": "string",
          "description": "Slug du fichier icône dans game_assets/talents/equipements/ (sans .png)"
        },
        "description": {
          "type": "string"
        },
        "prerequis": {
          "type": "string"
        },
        "estExotique": {
          "type": "boolean",
          "description": "True si talent exotique (dédié à un équipement exotique)."
        },
        "emplacement": {
          "type": "string",
          "enum": [
            "torse",
            "sac_a_dos",
            "masque",
            "holster",
            "gants",
            "genouilleres"
          ],
          "description": "Sur quel emplacement le talent peut être utilisé"
        },
        "perfectDescription": {
          "type": "string",
          "description": "Description de la version parfaite du talent"
        },
        "equipementsParfaits": {
          "type": "array",
          "description": "Noms des équipements nommés qui portent la version parfaite de ce talent",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
