{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Descente (partagé)",
  "description": "Données spécifiques au mode de jeu Descente",
  "type": "object",
  "required": [
    "boucles",
    "categorie",
    "levels"
  ],
  "properties": {
    "boucles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "categorie": {
      "type": "string",
      "enum": [
        "offensif",
        "defensif",
        "utilitaire",
        "exotique"
      ]
    },
    "notes": {
      "type": "string",
      "description": "Notes spécifiques au mode Descente"
    },
    "levels": {
      "type": "object",
      "required": [
        "base"
      ],
      "properties": {
        "base": {
          "type": "string",
          "description": "Description du talent avec variables : {var_name}, {other_var_name}..."
        }
      },
      "additionalProperties": {
        "type": "object",
        "description": "Valeurs des variables pour un niveau donné (ex: '1', '2', etc.)",
        "additionalProperties": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "number"
            }
          ]
        }
      }
    }
  },
  "additionalProperties": false
}
