{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Tags de Build",
  "description": "Clé = slug du tag.",
  "type": "object",
  "additionalProperties": false,
  "patternProperties": {
    "^[a-z0-9_]+$": {
      "type": "object",
      "required": ["label", "color"],
      "properties": {
        "label": {
          "type": "string",
          "description": "Nom affiché du tag"
        },
        "color": {
          "type": "string",
          "description": "Couleur CSS ou classe Tailwind associée"
        }
      }
    }
  }
}