  "medecin_de_combat": {
    "nom": "Médecin de combat",
    "description": "Vitesse de ranimation +80%\nTemps des malus d'affaiblissement -50%\nEfficacité de la ruche +45%\nConfère +50% de résistance aux dégâts à l'agent ranimé et au réanimateur pendant 5s après une ranimation de ruche réussie, ou 10s après une ranimation manuelle réussie.\nToute ranimation réussie donne +1 Tier de compétence pendant 5s.\nLes ranimations au Tier de compétence 6 donnent une surchage pendant 15s.",
    "emplacement": "sac_a_dos",
    "estExotique": true
  },
  "charge_toxique": {
    "nom": "Charge toxique",
    "description": "Les effets d'état infligent également un débuff de dégâts sur la durée pendant 10s.\nLe total de dégâts infligés est égal à 50% (20%) des dégâts de votre grenade offensive et est accru par vos attributs d'effet d'état.",
    "emplacement": "torse",
    "estExotique": true
  },
  "cercle_vicieux": {
    "nom": "Cercle vicieux",
    "description": "Subir des dégâts cumule des effets jusqu'à un maximum de 30.\nChaque effet confère +1,5% de dégâts d'arme.\nSubir des dégâts quand le cumul est à son maximum déclenche une purge qui consomme le cumul, supprime les effets d'état et génère un nuage qui restaure +5% de la protection maximum pendant 10s pour tous les alliés situés dans la zone d'effet.",
    "emplacement": "masque",
    "estExotique": true
  },
  "agent_chimique": {
    "nom": "Agent chimique",
    "description": "Catalyse :\nInfliger et subir des effets d'état permet d'accumuler des effets de Catalyse jusqu'à un maximum de 12.\nChaque effet confère : +2% dégâts d'arme et +2% d'effets d'état.\nChaque ennemi situé dans un rayon de 25m et affecté par un effet d'état confère +1 effet/s. Recevoir un effet d'état confère +2 effet/s.\nLes effets cumulés se dissipent au rythme de 1 effet(s)/s au bout de 5s si ni vous ni un ennemi à portée n'êtes affectés par un effet d'état.\n\nRéactif :\nQuand le cumul est à son maximum, tuer un ennemi subissant un effet d'état confère des bonus pendant 5s : +25% de protection bonus et +20% de vitesse de rechargement.\n\nStabilisation :\nPendant que vous êtes en feu, vous conservez votre capacité à viser.",
    "emplacement": "masque",
    "estExotique": true
  },
  "abrege": {
    "nom": "Abrégé",
    "description": "Si vos armes principale et secondaire ne sont pas exotiques ou spécifiées et du même type, le talent de l'arme secondaire sera également appliqué à l'arme principale.\nNe s'applique pas si le talent de l'arme principale ou secondaire inclut un changement d'arme.\nNe s'applique pas si les talents des armes principales et secondaire sont les mêmes.",
    "emplacement": "torse",
    "estExotique": true
  },
  "avantage_sanglant": {
    "nom": "Avantage sanglant",
    "description": "Endommager un ennemi situé à moins de 15m inflige un saignement à la cible.\nRépare 3-48% de votre protection par seconde pour chaque ennemi subissant un saignement situé à moins de 15m.\n- 1 ennemi : 3%\n- 2 ennemis : 6%\n- 3 ennemis : 12%\n- 4 ennemis : 24%\n- 5 ennemis : 48%",
    "emplacement": "torse",
    "estExotique": true
  },
  "hoarder": {
