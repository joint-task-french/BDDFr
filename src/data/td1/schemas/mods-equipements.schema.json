{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Mods d'équipements — The Division 2",
  "description": "Clé = slug du mod.",
  "type": "object",
  "additionalProperties": false,
  "patternProperties": {
    "^[a-z0-9_]+$": {
      "type": "object",
      "required": [
        "nom",
        "categorie"
      ],
      "properties": {
        "categorie": {
          "type": "string",
          "enum": [
            "offensif",
            "defensif",
            "utilitaire"
          ]
        },
        "nom": {
          "type": "string",
          "description": "Nom affiché du mod"
        },
        "attributs": {
          "type": "array",
          "description": "Attributs modifiés par ce mod (slug + valeur)",
          "items": {
            "type": "object",
            "required": [
              "attribut",
              "valeur"
            ],
            "properties": {
              "attribut": {
                "type": "string",
                "pattern": "^[a-z0-9_]+$"
              },
              "valeur": {
                "type": "number"
              }
            },
            "additionalProperties": false
          }
        },
        "bonus": {
          "type": "string",
          "description": "Effet textuel non lié à un attribut (optionnel)"
        },
        "notes": {
          "type": "string",
          "description": "Notes libres sur le mod"
        }
      }
    }
  }
}
