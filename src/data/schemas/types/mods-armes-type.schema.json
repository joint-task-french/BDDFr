{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Types de mods — The Division 2",
  "description": "Clé = slug du type de mod (ex: chargeur, canon, viseur, bouche). Valeur = objet avec le nom affiché.",
  "type": "object",
  "additionalProperties": false,
  "patternProperties": {
    "^[a-z0-9_]+$": {
      "type": "object",
      "required": ["nom"],
      "properties": {
        "nom": {
          "type": "string",
          "description": "Nom du type de mod"
        }
      },
      "additionalProperties": false
    }
  }
}
