{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Équipements — The Division 2",
  "description": "Toutes les pièces d'équipement. Clé = slug de l'équipement.",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "obtention": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string",
          "description": "Description de comment obtenir l'objet (peut être vide)"
        },
        "butinCible": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "string", "minLength": 1 }
          ],
          "description": "Disponible via butin ciblé — true/false ou string décrivant les conditions"
        },
        "cachesExotiques": {
          "type": "boolean",
          "description": "Disponible via caches exotiques"
        },
        "mission": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "string", "minLength": 1 }
          ],
          "description": "Disponible via une mission — true/false ou string décrivant les conditions"
        },
        "darkZone": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "string", "minLength": 1 }
          ],
          "description": "Disponible dans la Darkzone"
        },
        "raid": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "string", "minLength": 1 }
          ],
          "description": "Disponible via un raid — true/false ou string décrivant les conditions"
        },
        "craft": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "string", "minLength": 1 }
          ],
          "description": "Disponible au craft — true/false ou string décrivant les conditions"
        },
        "reconstitue": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "string", "minLength": 1 }
          ],
          "description": "Schemas disponible dans les caches reconstitué — true/false ou string décrivant les conditions"
        },
        "incursion": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "string", "minLength": 1 }
          ],
          "description": "Disponible via une incursion — true/false ou string décrivant les conditions"
        },
        "represailles": {
          "type": "string",
          "description": "Nom de la faction pour schémas représailles (optionnel)"
        }
      }
    }
  },
  "patternProperties": {
    "^[a-z0-9_]+$": {
      "type": "object",
      "required": [
        "nom",
        "emplacement"
      ],
      "properties": {
        "nom": {
          "type": "string"
        },
        "description" : {
          "type": "string",
          "description": "texte de lore lié a l'équipement"
        },
        "marque": {
          "type": "string",
          "pattern": "^([a-z0-9_]+|\\*)$",
          "description": "Slug de la marque/gear set, ou 'Exotique'"
        },
        "emplacement": {
          "type": "string",
          "enum": [
            "masque",
            "torse",
            "holster",
            "sac_a_dos",
            "gants",
            "genouilleres"
          ]
        },
        "attributEssentiel": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "offensif",
              "defensif",
              "utilitaire",
              "random"
            ]
          }
        },
        "attributs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "nom": {
                "type": "string",
                "pattern": "^[a-z0-9_]+$",
                "description": "Nom de l'attribut (doit correspondre à un nom dans attributs.jsonc)"
              },
              "valeur": {
                "type": "number",
                "description": "Valeur de l'attribut sur cet objet"
              },
              "prototypeValue": {
                "type": "number",
                "description": "Valeur de l'attribut sur cet objet si prototype"
              }
            },
            "additionalProperties": false,
            "anyOf": [
              {
                "maxProperties": 0
              },
              {
                "required": [
                  "nom"
                ]
              }
            ]
          }
        },
        "talents": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          }
        },
        "talentsPrototypes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          }
        },
        "mod": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "integer" }
          ]
        },
        "estNomme": {
          "type": "boolean"
        },
        "type": {
          "type": "string",
          "enum": [
            "improvise",
            "standard",
            "gear_set",
            "exotique"
          ]
        },
        "obtention": {
          "$ref": "#/definitions/obtention"
        },
        "notes": {
          "type": "string",
          "description": "Notes libres sur l'équipement"
        }
      }
    }
  }
}