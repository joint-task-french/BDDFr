{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Équipements — The Division 2",
  "description": "Toutes les pièces d'équipement. Clé = slug de l'équipement.",
  "type": "object",
  "additionalProperties": false,
  "patternProperties": {
    "^[a-z0-9_]+$": {
      "type": "object",
      "required": [
        "nom",
        "emplacement"
      ],
      "properties": {
        "nom": {
          "type": "string"
        },
        "description" : {
          "type": "string",
          "description": "texte de lore lié a l'équipement"
        },
        "marque": {
          "type": "string",
          "description": "Slug de la marque/gear set, ou 'Exotique'"
        },
        "emplacement": {
          "type": "string",
          "enum": [
            "masque",
            "torse",
            "holster",
            "sac_a_dos",
            "gants",
            "genouilleres"
          ]
        },
        "attributEssentiel": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "offensif",
              "défensif",
              "utilitaire"
            ]
          }
        },
        "attributUnique": {
          "type": "string"
        },
        "attributs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "nom",
              "valeur"
            ],
            "properties": {
              "nom": {
                "type": "string"
              },
              "valeur": {
                "type": "number"
              }
            }
          }
        },
        "talent": {
          "type": "string"
        },
        "talents": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "mod": {
          "type": "boolean"
        },
        "estNomme": {
          "type": "boolean"
        },
        "type": {
          "type": "string",
          "enum": [
            "standard",
            "gear_set",
            "exotique"
          ]
        },
        "obtention": {
          "type": "object",
          "description": "Comment obtenir l'équipement",
          "properties": {
            "description": {
              "type": "string",
              "description": "Description de comment obtenir l'objet (peut être vide)"
            },
            "butinCible": {
              "oneOf": [
                { "type": "boolean" },
                { "type": "string", "minLength": 1 }
              ],
              "description": "Disponible via butin ciblé — true/false ou string décrivant les conditions"
            },
            "cachesExotiques": {
              "type": "boolean",
              "description": "Disponible via caches exotiques"
            },
            "mission": {
              "oneOf": [
                { "type": "boolean" },
                { "type": "string", "minLength": 1 }
              ],
              "description": "Disponible via une mission — true/false ou string décrivant les conditions"
            },
            "darkZone": {
              "oneOf": [
                { "type": "boolean" },
                { "type": "string", "minLength": 1 }
              ],
              "description": "Disponible dans la Darkzone"
            },
            "raid": {
              "oneOf": [
                { "type": "boolean" },
                { "type": "string", "minLength": 1 }
              ],
              "description": "Disponible via un raid — true/false ou string décrivant les conditions"
            },
            "incursion": {
              "oneOf": [
                { "type": "boolean" },
                { "type": "string", "minLength": 1 }
              ],
              "description": "Disponible via une incursion — true/false ou string décrivant les conditions"
            },
            "represailles": {
              "type": "string",
              "description": "Nom de la faction pour schémas représailles (optionnel)"
            }
          }
        },
        "notes": {
          "type": "string",
          "description": "Notes libres sur l'équipement"
        }
      }
    }
  }
}
