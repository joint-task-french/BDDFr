{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Armes — The Division 2",
  "description": "Toutes les armes (classiques + exotiques) avec statistiques et talents. Clé = slug de l'arme.",
  "type": "object",
  "additionalProperties": false,
  "patternProperties": {
    "^[a-z0-9_]+$": {
      "type": "object",
      "required": [
        "nom",
        "type"
      ],
      "properties": {
        "nom": {
          "type": "string",
          "description": "Nom de l'arme"
        },
        "description" : {
          "type": "string",
          "description": "texte de lore lié a l'arme"
        },
        "icon": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$",
          "description": "Slug du fichier icône du talent exotique/nommé dans game_assets/talents/arme/ (sans .png)"
        },
        "type": {
          "type": "string",
          "enum": [
            "fusil_assaut",
            "fusil",
            "fusil_precision",
            "pistolet_mitrailleur",
            "fusil_mitrailleur",
            "calibre_12",
            "pistolet"
          ],
          "description": "Type/catégorie de l'arme"
        },
        "fabricant": {
          "type": "string",
          "description": "Fabricant de l'arme"
        },
        "portee": {
          "type": "number",
          "description": "Portée optimale en mètres"
        },
        "prototypePortee": {
          "type": "number",
          "description": "Portée optimale en mètres si prototype"
        },
        "rpm": {
          "type": "integer",
          "description": "Coups par minute"
        },
        "prototypeRpm": {
          "type": "integer",
          "description": "Coups par minute si prototype"
        },
        "chargeur": {
          "type": "integer",
          "description": "Taille du chargeur"
        },
        "prototypeChargeur": {
          "type": "integer",
          "description": "Taille du chargeur si prototype"
        },
        "rechargement": {
          "type": "number",
          "description": "Temps de rechargement en secondes"
        },
        "prototypeRechargement": {
          "type": "number",
          "description": "Temps de rechargement en secondes si prototype"
        },
        "headshot": {
          "type": "number",
          "description": "Multiplicateur de headshot en pourcentage (ex: 60 pour 60%)"
        },
        "prototypeHeadshot": {
          "type": "number",
          "description": "Multiplicateur de headshot en pourcentage si prototype"
        },
        "attributs": {
          "type": "array",
          "description": "Attributs fixés par défaut sur cette arme, avec leur valeur spécifique. Le nom référence un attribut dans attributs.jsonc.",
          "items": {
            "type": "object",
            "required": [
              "nom"
            ],
            "properties": {
              "nom": {
                "type": "string",
                "pattern": "^[a-z0-9_]+$",
                "description": "Nom de l'attribut (doit correspondre à un nom dans attributs.jsonc)"
              },
              "valeur": {
                "type": "number",
                "description": "Valeur de l'attribut sur cette arme"
              },
              "prototypeValue": {
                "type": "number",
                "description": "Valeur de l'attribut sur cette arme si prototype"
              }
            }
          }
        },
        "attributs_essentiels": {
          "type": "array",
          "description": "Écrase les attributs essentiels fixés par défaut sur cette arme, avec leur valeur spécifique. Le nom référence un attribut dans attributs.jsonc.",
          "items": {
            "type": "object",
            "required": [
              "nom"
            ],
            "properties": {
              "nom": {
                "type": "string",
                "pattern": "^[a-z0-9_]+$",
                "description": "Nom de l'attribut (doit correspondre à un nom dans attributs.jsonc)"
              },
              "valeur": {
                "type": "number",
                "description": "Valeur de l'attribut sur cette arme"
              },
              "prototypeValue": {
                "type": "number",
                "description": "Valeur de l'attribut sur cette arme si prototype"
              }
            }
          }
        },
        "degatsBase": {
          "type": "integer",
          "description": "Dégâts de base"
        },
        "prototypeDegatsBase": {
          "type": "integer",
          "description": "Dégâts de base si prototype"
        },
        "estExotique": {
          "type": "boolean",
          "description": "True si arme exotique"
        },
        "estNomme": {
          "type": "boolean",
          "description": "True si arme nommée (talent dédié fixe)"
        },
        "armePoing": {
          "type": "boolean",
          "description": "True si l'arme s'équipe dans l'emplacement Arme de poing (sidearm) même si son type est différent"
        },
        "talents": {
          "type": "array",
          "description": "Liste de slugs de talents (référencent les noms dans talents-armes.jsonc). Pour les exotiques, les talents dédiés sont directement dans cette liste.",
          "items": {
            "pattern": "^[a-z0-9_]+$",
            "type": "string"
          }
        },
        "talentsPrototypes": {
          "type": "array",
          "description": "Liste de slugs de talents prototypes (référencent les noms dans talents-prototypes.jsonc).",
          "items": {
            "pattern": "^[a-z0-9_]+$",
            "type": "string"
          }
        },
        "obtention": {
          "type": "object",
          "description": "Comment obtenir l'arme",
          "properties": {
            "description": {
              "type": "string",
              "description": "Description de comment obtenir l'objet (peut être vide)"
            },
            "butinCible": {
              "oneOf": [
                { "type": "boolean" },
                { "type": "string", "minLength": 1 }
              ],
              "description": "Disponible via butin ciblé — true/false ou string décrivant les conditions"
            },
            "cachesExotiques": {
              "type": "boolean",
              "description": "Disponible via caches exotiques"
            },
            "mission": {
              "oneOf": [
                { "type": "boolean" },
                { "type": "string", "minLength": 1 }
              ],
              "description": "Disponible via une mission — true/false ou string décrivant les conditions"
            },
            "darkZone": {
              "oneOf": [
                { "type": "boolean" },
                { "type": "string", "minLength": 1 }
              ],
              "description": "Disponible dans la Darkzone"
            },
            "raid": {
              "oneOf": [
                { "type": "boolean" },
                { "type": "string", "minLength": 1 }
              ],
              "description": "Disponible via un raid — true/false ou string décrivant les conditions"
            },
            "incursion": {
              "oneOf": [
                { "type": "boolean" },
                { "type": "string", "minLength": 1 }
              ],
              "description": "Disponible via une incursion — true/false ou string décrivant les conditions"
            },
            "represailles": {
              "type": "string",
              "description": "Nom de la faction pour schémas représailles (optionnel)"
            }
          }
        },
        "emplacementsMods": {
          "type": "object",
          "description": "Détail des emplacements spécifiques disponibles sur l'arme",
          "properties": {
            "chargeur": {
              "type": "string",
              "description": "Ex: chargeur_556",
              "enum": [
                "chargeur_556",
                "chargeur_762",
                "chargeur_762_precision",
                "chargeur_integre",
                "chargeur_pistolet",
                "barillet",
                "bande_munitions",
                "chargeur_45_acp",
                "chargeur_9mm",
                "magasin_tubulaire"
              ]
            },
            "canon": {
              "type": "string",
              "description": "Ex: rail_sous_canon_long",
              "enum": [
                "rail_sous_canon_long",
                "rail_sous_canon_court",
                "gadget",
                "lateral"
              ]
            },
            "viseur": {
              "type": "string",
              "description": "Ex: rail_optique_court",
              "enum": [
                "rail_optique_court",
                "rail_optique_long",
                "micro_rail_optique",
                "rail_optique"
              ]
            },
            "bouche": {
              "type": "string",
              "description": "Ex: bouche_556",
              "enum": [
                "bouche_45_acp",
                "bouche_45",
                "bouche_9mm",
                "bouche_556",
                "bouche_762",
                "bouche"
              ]
            }
          },
          "additionalProperties": false
        },
        "modsPredefinis": {
          "type": "array",
          "description": "Mods pré-équipés (armes exotiques) — non modifiables. Chaque entrée est le slug du mod.",
          "items": {
            "pattern": "^[a-z0-9_]+$",
            "type": "string"
          }
        },
        "notes": {
          "type": "string",
          "description": "Notes libres sur l'arme"
        }
      }
    }
  }
}
