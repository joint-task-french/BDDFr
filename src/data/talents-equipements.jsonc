    "emplacement": "torse"
  },
  "exploseur": {
    "nom": "Exploseur",
    "description": "Le rayon d'effet des grenades est accru +50%. Les grenades sont récupérées si elles tuent l'ennemi.Il est désormais possible d'ajuster le lancer des grenades en maintenant le bouton de tir enfoncé pour les faires exploser plus tôt.Confère +15% de protection bonus lorsque vous visez avec les grenades.",
    "prerequis": "n/a",
    "emplacement": "torse"
  },
  "zone_de_defense": {
    "nom": "Zone de défense",
    "description": "Les ennemis qui passent à moins de 3m de votre ruche, votre tourelle, ou votre impulsion télécommandée subissent une électrocution.Armement : 2sTemps de recharge par compétence : 10s",
    "prerequis": "n/a",
    "emplacement": "torse"
  },
  "efficace": {
    "nom": "Efficace",
    "description": "Employer un kit de protection à 50% de probabilité de ne pas consommer le kit de protection.Les bonus de kit de protection de spécialisation sont accrus de 100% (50%).10 secondes sont nécessaires pour armer le talent.",
    "prerequis": "n/a",
    "emplacement": "torse"
  },
  "retranchement": {
    "nom": "Retranchement",
    "description": "Si vous êtes à moins de 30% de votre protection, les headshots effectués depuis un abri réparent 20% de votre protection.Temps de recharge : 2s.",
    "prerequis": "n/a",
