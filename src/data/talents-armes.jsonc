  "munitions_desactivatrices": {
    "nom": "Munitions désactivatrices",
    "icone": "munitions_desactivatrices",
    "description": "Tirer sur un ennemi le marque et inflige un effet cumulable sur l'agent jusqu'à un maximum de 50. Tirer sur un ennemi marqué renouvelle la marque et ajoute des effets cumulables sur l'agent. Quand vous déployez une compétence non-bouclier, vous supprimez tous les effets cumulés sur l'agent et toute les cibles marquées déclenchent un effet.1 - 10 effets : Détecte et désactive les cibles marquées pendant 5s.11 - 25 effets : Détecte, désactive et désoriente les cibles marquées pendant 5s.26 - 49 effets : 50 stacks : Détecte, désactive et désoriente les cibles marquées ainsi que tous les ennemis à moins de 10m des cibles marquées pendant 5s.  Cet effet se déclenche immédiatement si un ennemi marqué est tué.",
    "estExotique": true
  },
  "marchand_de_sable": {
    "nom": "Marchand de sable",
    "icone": "marchand_de_sable",
    "description": "(PVE)Les attaques au corps à corps tuent instantanément les ennemis non élite.temps de recharge : 15s.",
    "estExotique": true
  },
  "choc_septique": {
    "nom": "Choc septique",
    "icone": "choc_septique",
    "description": "Tirer sur une cible lui des effets de venin qui durent 10 secondes. Le cumul d'effets aggrave les débuffs sur la cible.2 - Poison (Saignement)4 - Désorientation (Désactivation)6 - Électrocution (Immobilisation)9 - La cible subit 20% de dégâts supplémentaires (de toutes les sources). Le cumul n'augmente plus.La durée des effets d'état est basée sur le pourcentage de plombs qui atteignent leur cible lors du tir.",
    "estExotique": true
  },
  "capitulation": {
    "nom": "Capitulation",
    "icone": "capitulation",
    "description": "Toucher un ennemi inflige -4% à la vitesse de déplacement pour chaque plomb qui atteint la cible pendant 5s. Tirer à nouveau sur l'ennemi réapplique les effets cumulables.",
    "estExotique": true
  },
  "autentico": {
    "nom": "Autentico",
    "icone": "autentico",
    "description": "Dégâts d'arme +35%\nPrécision +100%\nPas de diminution des dégâts.\nCes bonus sont intégrés aux statistiques de base de l'arme.",
    "estExotique": true
  },
  "detente_binaire": {
    "nom": "Détente binaire",
    "icone": "detente_binaire",
    "description": "Cette arme tire lorsque l'utilisateur presse et relâche la détente.\nSi les deux balles touchent le même ennemi, vous gagnez un bonus.\nÀ 7 bonus, tirer sur un ennemi inflige des dégâts accrus de +500% et crée une explosion de 7m qui inflige 500% des dégâts d'arme et consomme les bonus cumulés.",
    "notes": "L'explosion fait 250% en pvp",
    "estExotique": true
  },
  "morsure_fatale": {
    "nom": "Morsure Fatale",
    "icone": "morsure_fatale",
    "description": "La Diamondback marque un ennemi désigné aléatoirement dans un rayon de 20m. S'il n'y a aucun ennemi dans les 20m, l'ennemi le plus proche de vous est marqué.\nToucher cet ennemi supprime la marque et assure un coup critique aux dégâts accrus de 20%.\nAprès avoir touché une marque, tous les tirs assurent des coups critiques pendant 5s.\nUn nouvel ennemi est marqué aléatoirement par la suite et à chaque fois que vous rechargez.",
    "estExotique": true
  },
  "geri_et_freki": {
    "nom": "Geri et Freki",
    "icone": "geri_et_freki",
    "description": "Tire des deux canons en même temps d'une seule pression sur la gâchette.\nUtilisé à l'épaule droite, ses tirs confèrent des effets offensifs. Utilisé à l'épaule gauche, ses tirs confèrent des effets défensifs.\nLes coups au but réalisés d'une épaule déclenchent tous les effets de l'épaule opposée.\nÀ l'activation chaque effet offensif infilge +100% des dégâts d'arme, et chaque effet défensif confère +4% de protection bonus et +10% de dégâts aux plaques de protection pendant 5s.\nLes effets voient leur efficacité doublée s'ils sont appliqués 10 fois.",
    "estExotique": true
  },
  "medecin_de_famille": {
    "nom": "Médecin de Famille",
    "icone": "medecin_de_famille",
    "description": "Tirer sur un ennemi avec cette arme applique une marque pendant 5 secondes.Si une cible marquée est tuée, elle lâche un kit de réparation de protection de 10% qui s'applique à tout le groupe automatiquement.Le kit ne confère pas de bonus d'armure.",
    "estExotique": true
  },
  "interface_d_assaut_ortiz": {
    "nom": "Interface d'assaut Ortiz",
    "icone": "interface_d_assaut_ortiz",
    "description": "En zoom, l'arme met en surbrillance une partie aléatoire du corps de chaque ennemi. L'arme inflige +60% de dégâts d'arme sur les parties de corps en surbrillance.",
    "estExotique": true
  },
  "transfusion": {
    "nom": "Transfusion",
    "icone": "transfusion",
    "description": "Réaliser des headshots cumule des effets jusqu'à un maximun de 8. Quand vous tirez sur un allié ou un proxy de compétence, vous les réparez de 50% de la valeur totale des dégâts de l'arme pour chaque effet cumulé.\nLes alliés soignés recevront 50% du bonus de vos compétences de réparation en bonus de protection pour chaque effet pendant 10s.\nAprès avoir soigné un allié ou une compétence, tous les tirs au but assurent des headshots pendant 8s si vous avez cumulé le maximun d'effets.",
    "estExotique": true
  },
  "frappe_de_l_aigle": {
    "nom": "Frappe de l'aigle",
    "icone": "frappe_de_l_aigle",
    "description": "La précision de vos tirs augmentent lorsque vous tirez en continu, jusqu'à +30%.\nLes éliminations par headshot confèrent le buff Ténacité pendant 15s.\nLa puissance de Ténacité est augmenté de 1% pour les dégâts corporels et de 5% pour les headshots.",
    "notes": "PVP : précision jusqu'à +100%, Ténacité pendant 10s",
    "estExotique": true
  },
  "tenacite": {
    "nom": "Ténacité",
    "icone": "tenacite",
    "description": "40-80% des dégâts subis sont retardés jusqu'à l'expiration du buff.\nL'intégralité du total de dégâts retardés est réduite pour chaque ennemi éliminé pendant que le buff était actif, jusqu'à 100% avec 3 éliminations.",
    "estExotique": true
  },
  "instinct_d_adaptation": {
    "nom": "Instinct d'adaptation",
    "icone": "instinct_d_adaptation",
    "description": "Placer 30 headshots confère +20% à la probalitité de coup critique et 50% aux dégâts de coup critique pendant 45 s.\nPlacer 65 tirs au corps confère +90% aux dégâts d'arme pendant 45 s.\nPlacer 20 tirs aux jambes confère +150% à la vitesse de rechargement pendant 45 s.\nLes buffs se réinitilialisent hors combat.",
    "estExotique": true
  },
  "chasseur_de_gros_gibier": {
    "nom": "Chasseur de gros gibier",
    "icone": "chasseur_de_gros_gibier",
    "description": "Quand vous zoomez, l'arme passe en mode semi-automatique et inflige 450% de dégâts d'armes à chaque tir.\nLes headshots confèrent +6% de dégâts headshot. Cet effet est cumulable 25 fois. Une fois le cumul maximum atteint, 10 effets se dissipent toutes les 4 secondes jusqu'à disparition de tous les effets. Les headshots ralentissent la disparition des effets.",
    "estExotique": true
  },
  "capacite": {
    "nom": "Capacité",
    "icone": "capacite",
    "description": "Tirer sur des ennemis cumule des effets jusqu'à un maximum de 40. Chaque effet confère 1.5% de dégâts de compétences. Au bout de 5 secondes, les effets cumulés diminuent de 1 par seconde.\nPour chaque Tier de compétence, confère 7.5% de dégâts d'arme.",
    "estExotique": true
  },
  "actum_est": {
    "nom": "Actum Est",
    "icone": "actum_est",
    "description": "Tirer sur un ennemi avec cette arme confère 1 effet cumulable.\nAu bout de 100, votre prochain chargeur contiendra des munitions électriques.",
    "notes": "50% du chargeur en pvp",
    "estExotique": true
  },
  "pertubation": {
    "nom": "Pertubation",
    "icone": "pertubation",
    "description": "Abattre un ennemi applique une marque à tous les ennemis situés à moins de 20m de lui. Il est possible d'appliquer plusieurs marques au même ennemi.\nLe nombre maximun de marques applicables est de 5. Toutes les marques sur un ennemi disparaissent 10s après la dernière d'entre elles a été appliquée.\nVous infligez +15% de dégâts par marque aux ennemis marqués.",
    "estExotique": true
  },
  "peste_des_parias": {
    "nom": "Peste des Parias",
    "icone": "peste_des_parias",
    "description": "Les coups au but appliquent un débuff qui inflige 100% des dégâts d'arme sur 10s. Cet effet est cumulable 50 fois.Quand un ennemi qui subit ce débuff meurt, le cumul d'effets est transféré à un ennemi situé dans un rayon de 25m.",
    "estExotique": true
  },
  "deluge_de_feu": {
    "nom": "Déluge de feu",
    "icone": "deluge_de_feu",
    "description": "Cette arme ne nécessite pas de rechargement.Pour chaque 100 balles qui touchent un ennemi, des munitions sont ajoutées dans votre réserve et celles de vos alliés",
    "estExotique": true
  },
  "ardent": {
    "nom": "Ardent",
    "icone": "ardent",
    "description": "Tirer chauffe l'arme, remplissant la jauge de chaleur. La jauge est équivalente à 50% de la capacité du chargeur de l'arme.Quand la jauge est pleine, les balles tirées par l'arme embrasse les ennemies.Lorsque vous ne tirez pas, la jauge se vide progressivement. Recharger ou changer d'arme vide complétement la jauge.",
    "estExotique": true
  },
  "pakhan": {
    "nom": "Pakhan",
    "icone": "pakhan",
    "description": "Chaque élimination avec cette arme augmente de +75% la capacité de base de votre chargeur pour le prochain chargeur, jusqu'à un maximun de 4 effets.",
    "estExotique": true
  },
  "accelerateur_electromagnetique": {
    "nom": "Accélérateur électromagnétique",
    "icone": "accelerateur_electromagnetique",
    "description": "Les tirs infligent 0-100% de dégâts en fonction du temps de pression avant de relâcher la détente.",
    "estExotique": true
  },
  "visee_analytique": {
    "nom": "Visée analytique",
    "icone": "visee_analytique",
    "description": "Votre vue zoomée affiche des informations supplémentaires sur les ennemis qui ne vous ciblent pas.\nLes dégâts de headshot et de point faible contre les ennemis qui ne vous ciblent pas sont augmentés de 50%.\nLes éliminations par headshot réinitialisent le temps de recharge de la compétence de leurre. Si le leurre est actif, cet effet s'applique quand le leurre passe en recharge.",
    "estExotique": true
  },
  "point_final": {
    "nom": "Point Final",
    "icone": "point_final",
    "description": "Les tirs sur vos ennemis génèrent un cumul pouvant atteindre 20 effets. Les headshot accumelent 2 effets. Chaque effet confère +2% de dégâts d'arme et de +5% de dégâts d'headshot. Au rechargement, le cumul d'effets est supprimé et vous gagnez +5% de protection maximum comme protection temporaire pendant 10s pour chaque effet cumulé.Les éliminations par headshot avec Effroyable Sentence réapprovisionnent intégralement le chargeur.Cet effet ne compte pas comme un rechargement.",
    "estExotique": true
  },
  "le_piege": {
    "nom": "Le piège",
    "icone": "le_piege",
    "description": "Marque les ennemis dans le champ de visée (10 maximum). Si l'agent tue une cible marquée avec un headshot, toutes les autres cibles subissent un malus de déplacement de 50% (20% en pvp) et Brûlure pendant 10s.\nTemps de recharge : 30s.\nTuer un autre ennemi par headshot diminue le temps de recharge de 10s.\nLes cibles sont marquées au bout de 1s en ligne de mire.",
    "estExotique": true
  },
  "cible_de_priorite_elevee": {
    "nom": "Cible de priorité élevée",
    "icone": "cible_de_priorite_elevee",
    "description": "Dégâts d'arme accrus de 125% contre les ennemi des rangs les plus élevés actuellement en combat, selon la hiérarchie des Tiers.\nTier 1 : chasseur, renégat, chef, tank, bouclier, armes lourdes, lance-roquettes, médecin, contrôleur, chien de guerre, maraudeur\nTier 2 : support, ingénieur, garde du corps, immobilisateur, poseur de bombe, mini-char, opérateur de drone\nTier 3 : tout autre ennemi ou proxy de compétence",
    "estExotique": true
  },
  "la_liberte_ou_la_mort": {
    "nom": "La Liberté ou la Mort",
    "icone": "la_liberte_ou_la_mort",
    "description": "Les tirs réussis confèrent un bonus de +2% aux dégâts d'arme. Cumulable jusqu'à 30 foisLes headshots consomment tout les effets cumulés pour réparer votre bouclier de 3% par effet",
    "estExotique": true
  },
  "regicide": {
    "nom": "Régicide",
    "icone": "regicide",
    "description": "Les éliminations par headshot créent une exploxion de 5m infligeant 400% des dégâts d'arme et saignement à tous les ennemis touchés.",
    "estExotique": true
  },
  "petite_abeille_ouvriere": {
    "nom": "Petite abeille ouvrière",
    "icone": "petite_abeille_ouvriere",
    "description": "Chaque tir sur une cible différente octroie 1 cumul, jusqu'à 10, chaque cumul conférant 20% (2%) d'augmentation de dégâts d'arme.Les cumuls s'activent une fois que l'agent change d'arme et durent 10 secondes.",
    "estExotique": true
  },
  "chanson_du_mosquito": {
    "nom": "Chanson du Mosquito",
    "icone": "chanson_du_mosquito",
    "description": "Toucher un ennemi lui attribue une marque cumulable. Les marques sont partagées par tous les joueurs.Au bout de 5 marques, l'ennemi est contraint de cibler le dernier joueur qui a attribué une marque pendant 5s et subit +25% de dégâts en plus à la protection.Les marques cumulées se dissipent toutes les 5s. Activer l'effet sur un ennemi supprime toutes les marques cumulées sur les autres ennemis.",
    "estExotique": true
  },
  "conversation_ininterrompue": {
    "nom": "Conversation ininterrompue",
    "icone": "conversation_ininterrompue",
    "description": "Quand vous rechargez, la cadence de tir pour l'intégralité du chargeur augmente de 25% pour chaque ennemi situé à moins de 15m.Cumulable 5 fois maximum.Les éliminations remplissent 50% de votre chargeur.",
    "estExotique": true
  },
  "souffle_ultime": {
    "nom": "Souffle ultime",
    "icone": "souffle_ultime",
    "description": "Quand vous vous déplacez, confère 4 bonus par seconde, 8 bonus si vous sprintez. Le nombre de bonus est équivalent à la taille du chargeur. Chaque munition tirée consomme un bonus qui augmente les dégâts de 75% (60%)Les éliminations confèrent +20% en vitesse de déplacement pendant 10s.",
    "estExotique": true
  },
  "paiement_en_nature": {
    "nom": "Paiement en nature",
    "icone": "paiement_en_nature",
    "description": "Infliger des dégâts aux ennemis ajoute un effet de 2% de dégâts critique. Le cumul d'effets peut atteindre 100 effets et dure 10s.Au rechargement, vous subissez un saignement infligeant 0,5% des dégâts de la protection par effet cumulé.",
    "estExotique": true
  },
  "rule_them_all": {
    "nom": "Rule them all",
    "icone": "rule_them_all",
    "description": "Quand l'agent subit un effet d'état, le prochain chargeur sera rempli à 50% du dernier effet d'état subit.Ne fonctionne qu'en combat.",
    "estExotique": true
  },
  "symbiose": {
    "nom": "Symbiose",
    "icone": "symbiose",
    "description": "Quand vous avez un bouclier déployé, vous perdez de la santé de bouclier au rythme de 10% par seconde.Votre bouclier reçoit des réparations équivalent à 25% des dégâts infligés par cette arme.",
    "estExotique": true
  },
  "courant_alternatif": {
    "nom": "Courant alternatif",
    "icone": "courant_alternatif",
    "description": "Génère un effet de 3% de dégâts de compétences pour une de vos compétences à chaque seconde, jusqu'à un maximum de 10 effets. Au bout de 10 secondes au maximum, les effets sont transférés à votre autre compétence. Le processus se répète ensuite indéfiniment.",
    "estExotique": true
  },
  "defibrillator": {
    "nom": "Defibrillator",
    "icone": "defibrillator",
    "description": "Lorsqu' \"Électrochoc\" est équipé, l'étourdissement de l'agent dû à l'effet d'électrocution est réduit de 50%. L'utilisation d'un bouclier permet d'augmenter les dégâts à corps à corps de 100%. En utilisant le Feu de Saint-Elme avec le Holster, vous infligerez 100% de dégâts au corps à corps supplémentaires et votre prochaine attaque au corps à corps électrocutera votre cible. En utilisant les trois objets, vous bénéficierez de tous les bonus mentionnés ci-dessus et l'électrocution provoquée par l'attaque au corps à corps portera sur un rayon de 5 m à partir de la première cible. 15 secondes de recharge.",
    "estExotique": true
  },
