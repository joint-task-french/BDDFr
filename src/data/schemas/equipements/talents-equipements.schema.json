{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Talents d'équipements",
  "description": "Clé = slug du talent.",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "descente": {
      "type": "object",
      "required": [
        "boucles",
        "categorie",
        "levels"
      ],
      "properties": {
        "boucles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "categorie": {
          "type": "string",
          "enum": [
            "offensif",
            "defensif",
            "utilitaire",
            "exotique"
          ]
        },
        "notes": {
          "type": "string",
          "description": "Notes spécifiques au mode Descente"
        },
        "levels": {
          "type": "object",
          "required": [
            "base"
          ],
          "properties": {
            "base": {
              "type": "string",
              "description": "Description du talent avec variables : {var_name}, {other_var_name}..."
            }
          },
          "additionalProperties": {
            "type": "object",
            "description": "Valeurs des variables pour un niveau donné (ex: '1', '2', etc.)",
            "additionalProperties": {
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "type": "number"
                }
              ]
            }
          }
        }
      },
      "additionalProperties": false
    }
  },
  "patternProperties": {
    "^[a-z0-9_]+$": {
      "type": "object",
      "required": [
        "nom",
        "emplacement"
      ],
      "anyOf": [
        { "required": ["description"] },
        { "required": ["perfectDescription"] }
      ],
      "properties": {
        "nom": {
          "type": "string"
        },
        "icon": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$",
          "description": "Slug du fichier icône dans game_assets/talents/equipements/ (sans .png)"
        },
        "description": {
          "type": "string"
        },
        "prerequis": {
          "type": "string"
        },
        "estExotique": {
          "type": "boolean",
          "description": "True si talent exotique (dédié à un équipement exotique)."
        },
        "emplacement": {
          "type": "string",
          "enum": [
            "torse",
            "sac_a_dos",
            "masque",
            "holster",
            "gants",
            "genouilleres",
            "gear_set"
          ],
          "description": "Sur quel emplacement le talent peut être utilisé"
        },
        "gearSet": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$",
          "description": "Slug de l'ensemble (si talent de gear set)"
        },
        "perfectDescription": {
          "type": "string",
          "description": "Description de la version parfaite du talent"
        },
        "equipementsParfaits": {
          "type": "array",
          "description": "Noms des équipements nommés qui portent la version parfaite de ce talent",
          "items": {
            "pattern": "^[a-z0-9_]+$",
            "type": "string"
          }
        },
        "notes": {
          "type": "string",
          "description": "Notes libres sur le talent"
        },
        "descente": {
          "$ref": "#/definitions/descente"
        }
      }
    }
  }
}