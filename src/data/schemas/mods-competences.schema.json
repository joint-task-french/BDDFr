{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Mods de compétences — The Division 2",
  "description": "Clé = slug du mod.",
  "type": "object",
  "additionalProperties": false,
  "patternProperties": {
    "^[a-z0-9_]+$": {
      "type": "object",
      "required": [
        "nom",
        "competence",
        "emplacement",
        "compatible",
        "attributs"
      ],
      "properties": {
        "nom": {
          "type": "string",
          "description": "Nom affiché du mod"
        },
        "competence": {
          "type": "string",
          "description": "Slug de la compétence associée"
        },
        "emplacement": {
          "type": "string",
          "description": "Emplacement du mod sur la compétence"
        },
        "compatible": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Slugs des compétences compatibles avec ce mod"
        },
        "prerequis": {
          "type": "string",
          "description": "Clé de spécialisation requise pour utiliser ce mod (optionnel)"
        },
        "attributs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["attribut", "valeur"],
            "properties": {
              "attribut": {
                "type": "string",
                "description": "Slug de la statistique affectée (depuis statistiques.jsonc)"
              },
              "valeur": {
                "type": "number",
                "description": "Valeur du bonus (en %)"
              }
            }
          },
          "description": "Attributs de la compétence modifiés par ce mod"
        }
      }
    }
  }
}
