// Talents d'équipements — The Division 2
{
  "complementarite": {
    "nom": "Complémentarité",
    "description": "Le dernier ennemi blessé par une compétence est marqué.Infliger des dégâts d'arme à cet ennemi supprime la marque et diminue les temps de recharge de 6s.Ne consomme pas la marque si aucune compétence n'est en recharge.Temps de recharge : 4s",
    "prerequis": "n/a",
    "emplacement": "torse"
  },
  "dynamisation": {
    "nom": "Dynamisation",
    "description": "Au combat, chaque compétence génère un bonus cumulable si elle est active ou si elle n'est pas en recharge.Ces bonus augmentent le total de dégâts de compétence de 1,5% et le total de réparation de compétence de 2%.Ils sont cumulables 15 fois maximum par compétence et s'annulent quand la compétence est en recharge.",
    "prerequis": "n/a",
    "emplacement": "sac_a_dos"
  },
  "doue": {
    "nom": "Doué",
    "description": "Les éliminations par compétence ont 25% de probabilité de réinitialiser les recharges de compétence.",
    "prerequis": "n/a",
    "emplacement": "sac_a_dos"
  },
  "observateur": {
    "nom": "Observateur",
    "description": "Augmente les totaux de dégâts d'arme et de dégâts de compétence de 15% contre les ennemis touchés par impulsion.",
    "prerequis": "n/a",
    "emplacement": "torse"
  },
  "livraison_explosive": {
    "nom": "Livraison Explosive",
    "description": "Quand vous déployez un objet de compétence, 1.5s après que celui-ci touche le sol, il génère une explosion infligeant des dégâts aux ennemis situés à moins de 5m.Les dégâts sont étalonnés selon le Tier de compétence et infligent 25-100% des dégâts d'une grenade offensive.Une fois maximum par compétence.",
    "prerequis": "n/a",
    "emplacement": "torse"
  },
  "determination_empathique": {
    "nom": "Détermination Empathique",
    "description": "Réparer un allié augmente ses totaux de dégâts d'arme et de dégâts de compétence de 3-15% pendant 20s.Sur soi, le bénéfice est de 1-7%.L'efficacité augmente en fonction de votre Tier de compétence.",
    "prerequis": "n/a",
    "emplacement": "torse"
  },
  "observation": {
    "nom": "Observation",
    "description": "Au bout de 10s à couvert, augmente les totaux de dégâts d'arme et de dégâts de compétence de 12% pour vous et vos alliés.Cet effet dure tant que vous restez à couvert ou que vous vous déplacez d'un abri à l'autre.",
    "prerequis": "n/a",
    "emplacement": "torse"
  },
  "intimidation": {
    "nom": "Intimidation",
    "description": "Quand vous disposez d'une protection bonus,vous gagnez 3 effets chaque seconde jusqu'à un max de 9. Chaque effet cumulé augmente les dégâts d'arme de +4% contre les ennemis situés à moins de 10m.Tous les effets cumulés sont perdus si vous n'avez plus de protection bonus.",
    "prerequis": "n/a",
    "emplacement": "torse"
  },
  "incassable": {
    "nom": "Incassable",
    "description": "Quand votre protection est détruite, répare 95% (50%) de votre protection.Temps de recharge : 60s",
    "prerequis": "n/a",
    "emplacement": "torse"
  },
  "avant_garde": {
    "nom": "Avant-garde",
    "description": "Déployer un bouclier le rend invulnérable pendant 5s (2s) et donne à tous les autres alliés 45% (20%) de votre protection en protection bonus pendant 20s.Temps de recharge : 25s.",
    "prerequis": "n/a",
    "emplacement": "torse"
  },
  "rechargement_protege": {
    "nom": "Rechargement Protégé",
    "description": "Confère +20% de protection bonus quand vous rechargez.Confère 0-18% de votre protection en protection bonus pour tout vos alliés quand ceux-ci rechargent, en fonction de votre attribut essentiel bleu",
    "prerequis": "n/a",
    "emplacement": "torse"
  },
  "canon_de_verre": {
    "nom": "Canon de verre",
    "description": "Tous les dégâts que vous infligez sont accrus de 25%.Tous les dégâts que vous subissez sont accrus de 50%.",
    "prerequis": "n/a",
    "emplacement": "torse",
    "perfectDescription": "Tous les dégâts que vous infligez sont accrus de 30%.Tous les dégâts que vous subissez sont accrus de 60%.",
    "equipementsParfaits": [
      "sacrifice"
    ]
  },
  "degaineur": {
    "nom": "Dégaineur",
