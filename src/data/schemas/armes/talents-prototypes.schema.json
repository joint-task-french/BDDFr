{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Talents Prototypes",
  "description": "Clé = slug du talent.",
  "type": "object",
  "additionalProperties": false,
  "patternProperties": {
    "^[a-z0-9_]+$": {
      "type": "object",
      "required": [
        "nom",
        "description",
        "statMin",
        "statMax",
        "pas"
      ],
      "properties": {
        "nom": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "statMin": {
          "type": "number"
        },
        "statMax": {
          "type": "number"
        },
        "pas": {
          "type": "number"
        },
        "icon": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$",
          "description": "Slug du fichier icône dans game_assets/talents/prototypes/ (sans .png)"
        }
      }
    }
  }
}
